model records {
  id                 Int       @id @default(autoincrement())
  title              String?
  number             String?
  date_issued        String?
  details            String?
  date_effectivity   String?
  status             String?
  related_ordinances String?
  file_path          String?
  document_type      String?
  is_deleted         String?
  sponsor            String?
  download_count     Int?
  created_at         DateTime? @default(now())
  updated_at         DateTime  @updatedAt
  deleted_at         DateTime?
}
