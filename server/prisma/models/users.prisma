model Users {
  id        String   @id @default(uuid())
  name      String?
  email     String   @unique
  password  String
  office_id String?
  role      Role?    @default(USER)
  isActive  Boolean  @default(false)
  office    Offices? @relation(fields: [office_id], references: [id])
}

enum Role {
  ADMIN
  USER
  SUPER_ADMIN
}
